# BookMe Environment Configuration
# Copy to .env.bookme and customize for your environment

# === Application ===
NODE_ENV=production
APP_NAME=bookme
APP_VERSION=1.0.0
LOG_LEVEL=info

# === Server ===
HOST=0.0.0.0
PORT=3000
NEXT_PUBLIC_API_URL=https://api.bookme.yourdomain.com

# === Data Storage ===
BOOKME_DATA_DIR=/var/lib/bookme
PROJECT_DATA_DIR=/var/lib/projects
GOOGLE_DRIVE_CACHE_DIR=/var/cache/bookme

# === Database (Optional - currently file-based) ===
DATABASE_URL=
DATABASE_POOL_SIZE=10

# === Authentication (Optional) ===
AUTH_ENABLED=false
JWT_SECRET=your-secret-key-here
SESSION_SECRET=your-session-secret-here
OAUTH_PROVIDER=github
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# === Integrations ===
GOOGLE_DRIVE_ENABLED=true
GOOGLE_DRIVE_API_KEY=

# === Email (Optional) ===
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@bookme.yourdomain.com

# === Monitoring & Analytics ===
SENTRY_DSN=
LOGROCKET_ID=
DATADOG_APP_KEY=
DATADOG_API_KEY=

# === Security ===
ENABLE_HTTPS=true
SSL_CERT_PATH=/etc/ssl/certs/bookme.crt
SSL_KEY_PATH=/etc/ssl/private/bookme.key
CORS_ORIGINS=https://bookme.yourdomain.com,https://app.bookme.yourdomain.com
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=1000

# === Performance ===
CACHE_ENABLED=true
CACHE_TTL=3600
ENABLE_COMPRESSION=true
ENABLE_CDN=true
CDN_URL=https://cdn.bookme.yourdomain.com

# === Development/Debug ===
DEBUG=false
VERBOSE_LOGGING=false
ENABLE_PROFILING=false
ENABLE_SWAGGER=false

# === Backup & Recovery ===
BACKUP_ENABLED=true
BACKUP_DIR=/var/backups/bookme
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# === Feature Flags ===
FEATURE_COLLABORATIVE_EDITING=false
FEATURE_PDF_EXPORT=true
FEATURE_EPUB_EXPORT=false
FEATURE_PUBLISH_TO_STORE=false

# === Deployment ===
DEPLOYMENT_ENV=production
DEPLOYMENT_REGION=us-east-1
DEPLOYMENT_AUTO_SCALE=true
DEPLOYMENT_MIN_REPLICAS=1
DEPLOYMENT_MAX_REPLICAS=10
