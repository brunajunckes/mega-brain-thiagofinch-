# OpenClaw + AIOX Configuration for GLM-4.7:cloud (Remote)
# Use this to run both aiox-ollama and openclaw with GLM-4.7:cloud as PRIMARY model

# ============================================================================
# LLM CONFIGURATION
# ============================================================================

# Use Ollama backend (works with both local and remote models)
AIOX_OFFLINE_MODE=true

# Primary LLM Model: GLM-4.7:cloud (remote via Ollama)
OLLAMA_PRIMARY_MODEL=glm-4.7:cloud
OLLAMA_MODEL=glm-4.7:cloud

# Ollama Configuration
# For local Ollama:
OLLAMA_URL=http://localhost:11434

# For remote Ollama (if applicable):
# OLLAMA_URL=https://your-ollama-server.com
# OLLAMA_API_KEY=your-api-key-if-needed

# ============================================================================
# EVOLUTION WORKER CONFIGURATION
# ============================================================================

# Use Ollama backend (GLM-4.7:cloud) for Evolution Workers
EVOLUTION_BACKEND=ollama
OPENCLAW_BACKEND=ollama

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable remote model support
OLLAMA_ENABLE_REMOTE=true

# Model timeout (increase for remote models)
OLLAMA_TIMEOUT=120000

# ============================================================================
# USAGE
# ============================================================================

# Load this configuration:
# source /srv/aiox/.env.glm-remote-example

# Then run:
# aiox-ollama status                    # Shows GLM-4.7:cloud as primary
# openclaw status                       # Shows GLM-4.7:cloud as primary
# python3 /srv/openclaw/evolution-worker.py  # Uses GLM-4.7:cloud

# ============================================================================
# IMPORTANT NOTES
# ============================================================================

# 1. GLM-4.7:cloud requires network connection
# 2. Ensure Ollama is configured to access the remote model
# 3. Both aiox-ollama and openclaw will use GLM-4.7:cloud automatically
# 4. Fallback models (qwen2.5, deepseek-coder) are available if GLM unavailable
# 5. All three systems (aiox, aiox-ollama, openclaw) can run in parallel
